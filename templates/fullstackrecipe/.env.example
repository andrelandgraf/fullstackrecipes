# =============================================================================
# Fullstack Recipe Template — environment variables
# Copy to .env.development (and .env.production) and fill in real values.
# Required configs are validated at build time via `bun run env:validate`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Neon Postgres) — REQUIRED
# Get from https://console.neon.tech (use the pooled connection string).
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# AI — REQUIRED (set ONE of the following)
# Uses the Vercel AI Gateway. On Vercel, VERCEL_OIDC_TOKEN is injected
# automatically. Locally, set an AI Gateway API key instead.
# -----------------------------------------------------------------------------
AI_GATEWAY_API_KEY=""
VERCEL_OIDC_TOKEN=""

# Optional: direct provider keys if you swap src/lib/ai/config.ts to use them.
# OPENAI_API_KEY="sk-..."
# GOOGLE_GENERATIVE_AI_API_KEY="..."

# -----------------------------------------------------------------------------
# Better Auth — REQUIRED
# Generate the secret with: openssl rand -base64 32
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Resend (transactional email) — REQUIRED
# RESEND_FROM_EMAIL must match the "Name <email@domain.com>" format.
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_your_api_key"
RESEND_FROM_EMAIL="Your App <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# Public origin — used by Stripe redirects and webhooks
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# Stripe (subscriptions) — OPTIONAL. The template builds and runs with billing
# off. Set NEXT_PUBLIC_ENABLE_STRIPE=true and the keys below to enable it.
# Get keys from https://dashboard.stripe.com/apikeys
# STRIPE_WEBHOOK_SECRET comes from `bun run dev:stripe` (local) or
# `bun run start:stripe` (creates a production webhook endpoint).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_STRIPE="false"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRO_PRICE_ID="price_..."

# -----------------------------------------------------------------------------
# Sentry (error monitoring) — required only when NEXT_PUBLIC_ENABLE_SENTRY=true
# DSN/org/project are not secrets. SENTRY_AUTH_TOKEN is used for source maps.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_SENTRY="false"
NEXT_PUBLIC_SENTRY_DSN="https://your-dsn@sentry.io/your-project-id"
NEXT_PUBLIC_SENTRY_ORG="andre-landgraf"
NEXT_PUBLIC_SENTRY_PROJECT="fullstackrecipes"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# -----------------------------------------------------------------------------
# Neon test branches — required only for `bun run test*`
# Get from the Neon Console (Account Settings > API Keys; project dashboard URL).
# -----------------------------------------------------------------------------
NEON_API_KEY="your-neon-api-key"
NEON_PROJECT_ID="your-neon-project-id"
